{{- $person := site.Data.profile.person -}}
{{- $meta := site.Data.ai.endpoints.experiences -}}
{{- $records := partial "func/get-profile-experiences.html" . -}}
{{- dict
  "title" $meta.title
  "description" (strings.TrimSpace $meta.description)
  "person_id" $person.id
  "person_url" $person.url
  "generated_at" (now.Format "2006-01-02")
  "count" (len $records)
  "experiences" $records
  | jsonify -}}
