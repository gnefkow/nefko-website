{{- $meta := site.Data.ai.endpoints -}}
{{- $resources := partial "func/get-ai-catalog-resources.html" . -}}
{{- dict
  "title" $meta.catalog.title
  "description" (strings.TrimSpace $meta.catalog.description)
  "generated_at" (now.Format "2006-01-02")
  "count" (len $resources)
  "resources" $resources
  | jsonify -}}
